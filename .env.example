# Shopify App Credentials
SHOPIFY_API_KEY="your-api-key"
SHOPIFY_API_SECRET="your-api-secret"
SCOPES="write_products,write_script_tags,read_script_tags"
SHOPIFY_APP_URL="https://your-app-url.vercel.app"

# Database (PostgreSQL — required for production)
# Use Vercel Postgres, Neon, Supabase, or any PostgreSQL provider
# For Neon pooled connections, add ?pgbouncer=true&connect_timeout=15
DATABASE_URL="postgresql://user:password@host-pooler:5432/badgehq?sslmode=require&pgbouncer=true&connect_timeout=15"
# For Neon direct connections (used for migrations), use the non-pooler endpoint
DATABASE_POSTGRES_URL_NON_POOLING="postgresql://user:password@host:5432/badgehq?sslmode=require&connect_timeout=15"

# Optional
SHOP_CUSTOM_DOMAIN=""
