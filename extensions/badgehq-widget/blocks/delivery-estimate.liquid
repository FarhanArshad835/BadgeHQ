{%- comment -%}
  BadgeHQ: Delivery-estimate-by-PIN block for the product page.
  Merchant places this app block under the buy buttons in the theme editor.
  The delivery date comes from the BadgeHQ backend (Delhivery Expected TAT),
  configured in the BadgeHQ admin. The Delhivery token never reaches the browser.
  Until the merchant configures + enables the feature, the widget stays silent.
{%- endcomment -%}

<script src="{{ 'delivery-estimate.js' | asset_url }}" defer="defer"></script>

<div
  class="de-widget"
  data-delivery-estimate
  data-de-endpoint="https://badgehq-widget.badgehq.workers.dev/api/delivery-edd"
  data-de-shop="{{ shop.permanent_domain }}"
  data-de-deliverby="{{ block.settings.deliver_by_text | escape }}"
  {% if block.settings.show_free_delivery %}data-de-free="{{ block.settings.free_delivery_text | escape }}"{% endif %}
  {% if block.settings.show_faster_note %}data-de-faster="{{ block.settings.faster_note_text | escape }}"{% endif %}
  {{ block.shopify_attributes }}
>
  <div class="de-widget__label">
    <svg class="de-icon" viewBox="0 0 24 24" width="18" height="18" aria-hidden="true">
      <path fill="currentColor" d="M12 2a7 7 0 0 0-7 7c0 5 7 13 7 13s7-8 7-13a7 7 0 0 0-7-7Zm0 9.5A2.5 2.5 0 1 1 12 6.5a2.5 2.5 0 0 1 0 5Z"/>
    </svg>
    <span>{{ block.settings.heading }}</span>
  </div>

  <form class="de-widget__form" data-de-form novalidate>
    <input
      class="de-widget__input"
      data-de-input
      type="text"
      inputmode="numeric"
      pattern="\d{6}"
      maxlength="6"
      autocomplete="postal-code"
      placeholder="{{ block.settings.placeholder }}"
      aria-label="{{ block.settings.heading }} — {{ block.settings.placeholder }}"
    >
    <button class="de-widget__button" data-de-button type="submit">{{ block.settings.button_label }}</button>
  </form>

  <div class="de-widget__result" data-de-result data-de-state="idle" aria-live="polite"></div>
</div>

{%- style -%}
  .de-widget {
    margin: 16px 0;
    padding: 14px 16px;
    border: 1px solid rgba(var(--color-foreground, 18 18 18), 0.12);
    border-radius: var(--buttons-radius, 6px);
    font-size: 1.4rem;
  }
  .de-widget[data-de-hidden] { display: none; }
  .de-widget__label {
    display: flex;
    align-items: center;
    gap: 6px;
    font-weight: 600;
    margin-bottom: 10px;
  }
  .de-widget__label .de-icon { flex: none; opacity: 0.75; }
  .de-widget__form {
    display: flex;
    gap: 8px;
    align-items: stretch;
  }
  .de-widget__input {
    flex: 1 1 auto;
    min-width: 0;
    padding: 10px 12px;
    font: inherit;
    font-size: 1.4rem;
    color: rgb(var(--color-foreground, 18 18 18));
    background: rgb(var(--color-background, 255 255 255));
    border: 1px solid rgba(var(--color-foreground, 18 18 18), 0.2);
    border-radius: var(--inputs-radius, 4px);
    letter-spacing: 0.05em;
  }
  .de-widget__input:focus {
    outline: none;
    border-color: rgb(var(--color-foreground, 18 18 18));
  }
  .de-widget__button {
    flex: none;
    padding: 10px 18px;
    font: inherit;
    font-weight: 600;
    cursor: pointer;
    color: rgb(var(--color-button-text, 255 255 255));
    background: rgb(var(--color-button, 18 18 18));
    border: 1px solid transparent;
    border-radius: var(--buttons-radius, 4px);
  }
  .de-widget__button:disabled { opacity: 0.6; cursor: default; }
  .de-widget__result {
    margin-top: 10px;
    min-height: 0;
    line-height: 1.4;
  }
  .de-widget__result[data-de-state="idle"] { margin-top: 0; }
  .de-widget__result[data-de-state="ok"] { color: #157a3d; }
  .de-widget__result[data-de-state="unserviceable"],
  .de-widget__result[data-de-state="error"] { color: rgb(var(--color-foreground, 18 18 18)); opacity: 0.85; }
  .de-widget__result .de-icon { vertical-align: -2px; margin-right: 4px; }
  .de-widget__result strong { font-weight: 700; }
  .de-widget__row { display: flex; align-items: center; gap: 6px; }
  .de-widget__row .de-icon { flex: none; vertical-align: baseline; margin-right: 0; }
  .de-widget__row + .de-widget__row { margin-top: 4px; }
  .de-widget__faster { color: rgb(var(--color-foreground, 18 18 18)); opacity: 0.7; font-size: 0.92em; }
  .de-spinner {
    display: inline-block;
    width: 13px; height: 13px;
    margin-right: 4px;
    vertical-align: -1px;
    border: 2px solid currentColor;
    border-right-color: transparent;
    border-radius: 50%;
    animation: de-spin 0.6s linear infinite;
  }
  @keyframes de-spin { to { transform: rotate(360deg); } }
  @media (prefers-reduced-motion: reduce) { .de-spinner { animation-duration: 2s; } }
{%- endstyle -%}

{% schema %}
{
  "name": "Delivery Estimate",
  "target": "section",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "Estimate delivery date" },
    { "type": "text", "id": "button_label", "label": "Button label", "default": "Check" },
    { "type": "text", "id": "placeholder", "label": "Input placeholder", "default": "Enter 6-digit PIN code" },
    { "type": "text", "id": "deliver_by_text", "label": "Delivery date prefix", "default": "Delivery by", "info": "Shown before the date, e.g. \"Delivery by Sun, 19 Jul\"." },
    { "type": "checkbox", "id": "show_free_delivery", "label": "Show a free-delivery line", "default": false },
    { "type": "text", "id": "free_delivery_text", "label": "Free-delivery text", "default": "Free delivery" },
    { "type": "checkbox", "id": "show_faster_note", "label": "Show a \"faster at checkout\" note", "default": false },
    { "type": "text", "id": "faster_note_text", "label": "Note text", "default": "Faster delivery methods available at checkout" }
  ]
}
{% endschema %}
