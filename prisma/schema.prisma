generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DATABASE_POSTGRES_URL_NON_POOLING")
}

model Session {
  id                    String    @id
  shop                  String
  state                 String
  isOnline              Boolean   @default(false)
  scope                 String?
  expires               DateTime?
  accessToken           String?
  userId                BigInt?
  firstName             String?
  lastName              String?
  email                 String?
  accountOwner          Boolean   @default(false)
  locale                String?
  collaborator          Boolean?  @default(false)
  emailVerified         Boolean?  @default(false)
  refreshToken          String?
  refreshTokenExpires   DateTime?
}

model TrustBadge {
  id        String   @id @default(cuid())
  shop      String
  name      String   @default("Trust Badge")
  isEnabled Boolean  @default(false)
  badgeIds  String   @default("[]")
  settings  String   @default("{}")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([shop])
}

model ProductBadge {
  id         String   @id @default(cuid())
  shop       String
  text       String   @default("Sale")
  badgeType  String   @default("text")
  shape      String   @default("rectangle")
  badgeColor String   @default("#e74c3c")
  textColor  String   @default("#ffffff")
  position   String   @default("top-left")
  placement  String   @default("image")
  targeting  String   @default("{\"type\":\"all\"}")
  isActive   Boolean  @default(false)

  // ShineTrust-level features
  condition  String   @default("{\"type\":\"none\"}")
  pages      String   @default("[\"all\"]")
  schedule   String   @default("{}")
  priority   Int      @default(0)
  imageUrl   String   @default("")
  fontSize   Int      @default(11)
  fontSizeMobile Int  @default(11)
  opacity    Float    @default(1.0)
  rotation   Int      @default(0)
  gradient   String   @default("")
  borderColor String  @default("")
  borderWidth Int     @default(0)
  customCSS  String   @default("")

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([shop])
}

model AnnouncementBar {
  id        String   @id @default(cuid())
  shop      String
  messages  String   @default("[{\"text\":\"Welcome to our store!\",\"emoji\":\"\"}]")
  bgColor   String   @default("#000000")
  textColor String   @default("#ffffff")
  isActive  Boolean  @default(false)
  showClose Boolean  @default(true)
  pages     String   @default("[\"all\"]")
  schedule  String   @default("{}")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([shop])
}

model FreeShippingBar {
  id        String   @id @default(cuid())
  shop      String
  threshold Float    @default(50.0)
  messages  String   @default("{\"below\":\"You're {{amount}} away from free shipping!\",\"reached\":\"Congratulations! You've earned free shipping!\"}")
  colors    String   @default("{\"barBg\":\"#f0f0f0\",\"progressBg\":\"#4caf50\",\"text\":\"#333333\"}")
  isActive  Boolean  @default(false)
  pages     String   @default("[\"cart\",\"product\"]")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([shop])
}

model StickyCart {
  id             String  @id @default(cuid())
  shop           String
  buttonText     String  @default("Add to Cart")
  buttonColor    String  @default("#ffffff")
  bgColor        String  @default("#000000")
  textColor      String  @default("#ffffff")
  buttonStyle    String  @default("solid")
  buttonRadius   String  @default("6")
  showPrice      Boolean @default(true)
  showQuantity   Boolean @default(true)
  alwaysShow     Boolean @default(false)
  showMobile     Boolean @default(true)
  showDesktop    Boolean @default(true)
  position       String  @default("bottom")
  isActive       Boolean @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([shop])
}

model CountdownTimer {
  id        String   @id @default(cuid())
  shop      String
  endDate   DateTime
  style     String   @default("full")
  messages  String   @default("{\"above\":\"Hurry! Sale ends in:\",\"below\":\"Don't miss out!\"}")
  colors    String   @default("{\"bg\":\"#000000\",\"text\":\"#ffffff\",\"accent\":\"#e74c3c\"}")
  isActive  Boolean  @default(false)
  pages     String   @default("[\"product\"]")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([shop])
}

model AppSettings {
  id        String   @id @default(cuid())
  shop      String   @unique
  isEnabled Boolean  @default(true)
  settings  String   @default("{\"fontFamily\":\"inherit\",\"colorScheme\":\"light\"}")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model DeliverySettings {
  id          String   @id @default(cuid())
  shop        String   @unique
  isEnabled   Boolean  @default(false)
  apiToken    String   @default("")
  originPin   String   @default("")
  bufferDays   Int     @default(1)
  environment  String  @default("staging")
  placement    String  @default("below-atc")
  deliveryMode String  @default("standard") // "standard" | "express" | "both"
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model OrderManageSettings {
  id               String   @id @default(cuid())
  shop             String   @unique
  isEnabled        Boolean  @default(false)
  allowCancel      Boolean  @default(true)
  cancelScope      String   @default("unpaid") // "unpaid" | "all"
  allowAddressEdit Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model WishlistSettings {
  id               String   @id @default(cuid())
  shop             String   @unique
  isEnabled        Boolean  @default(false)
  showOnCards      Boolean  @default(true)
  cardPosition     String   @default("top-right") // top-right | top-left
  showOnProduct    Boolean  @default(true)
  productPlacement String   @default("below-atc") // below-atc | above-atc
  showHeader       Boolean  @default(true)
  iconColor        String   @default("#e74c3c")
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model Wishlist {
  id         String   @id @default(cuid())
  shop       String
  customerId String
  handles    String   @default("[]") // JSON array of product handles
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([shop, customerId])
}

model ShopPlan {
  id        String   @id @default(cuid())
  shop      String   @unique
  plan      String   @default("free")
  billingId String?
  status    String   @default("active")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
