generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DATABASE_POSTGRES_URL_NON_POOLING")
}

model Session {
  id                    String    @id
  shop                  String
  state                 String
  isOnline              Boolean   @default(false)
  scope                 String?
  expires               DateTime?
  accessToken           String?
  userId                BigInt?
  firstName             String?
  lastName              String?
  email                 String?
  accountOwner          Boolean   @default(false)
  locale                String?
  collaborator          Boolean?  @default(false)
  emailVerified         Boolean?  @default(false)
  refreshToken          String?
  refreshTokenExpires   DateTime?
}

model TrustBadge {
  id        String   @id @default(cuid())
  shop      String
  name      String   @default("Trust Badge")
  isEnabled Boolean  @default(false)
  badgeIds  String   @default("[]")
  settings  String   @default("{}")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([shop])
}

model ProductBadge {
  id         String   @id @default(cuid())
  shop       String
  text       String   @default("Sale")
  badgeType  String   @default("text")
  shape      String   @default("rectangle")
  badgeColor String   @default("#e74c3c")
  textColor  String   @default("#ffffff")
  position   String   @default("top-left")
  placement  String   @default("image")
  targeting  String   @default("{\"type\":\"all\"}")
  isActive   Boolean  @default(false)

  // ShineTrust-level features
  condition  String   @default("{\"type\":\"none\"}")
  pages      String   @default("[\"all\"]")
  schedule   String   @default("{}")
  priority   Int      @default(0)
  imageUrl   String   @default("")
  fontSize   Int      @default(11)
  fontSizeMobile Int  @default(11)
  opacity    Float    @default(1.0)
  rotation   Int      @default(0)
  gradient   String   @default("")
  borderColor String  @default("")
  borderWidth Int     @default(0)
  customCSS  String   @default("")

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([shop])
}

model AnnouncementBar {
  id        String   @id @default(cuid())
  shop      String
  messages  String   @default("[{\"text\":\"Welcome to our store!\",\"emoji\":\"\"}]")
  bgColor   String   @default("#000000")
  textColor String   @default("#ffffff")
  isActive  Boolean  @default(false)
  showClose Boolean  @default(true)
  pages     String   @default("[\"all\"]")
  schedule  String   @default("{}")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([shop])
}

model FreeShippingBar {
  id        String   @id @default(cuid())
  shop      String
  threshold Float    @default(50.0)
  messages  String   @default("{\"below\":\"You're {{amount}} away from free shipping!\",\"reached\":\"Congratulations! You've earned free shipping!\"}")
  colors    String   @default("{\"barBg\":\"#f0f0f0\",\"progressBg\":\"#4caf50\",\"text\":\"#333333\"}")
  isActive  Boolean  @default(false)
  pages     String   @default("[\"cart\",\"product\"]")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([shop])
}

model StickyCart {
  id             String  @id @default(cuid())
  shop           String
  buttonText     String  @default("Add to Cart")
  buttonColor    String  @default("#ffffff")
  bgColor        String  @default("#000000")
  textColor      String  @default("#ffffff")
  buttonStyle    String  @default("solid")
  buttonRadius   String  @default("6")
  showPrice      Boolean @default(true)
  showQuantity   Boolean @default(true)
  alwaysShow     Boolean @default(false)
  showMobile     Boolean @default(true)
  showDesktop    Boolean @default(true)
  position       String  @default("bottom")
  isActive       Boolean @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([shop])
}

model CountdownTimer {
  id        String   @id @default(cuid())
  shop      String
  endDate   DateTime
  style     String   @default("full")
  messages  String   @default("{\"above\":\"Hurry! Sale ends in:\",\"below\":\"Don't miss out!\"}")
  colors    String   @default("{\"bg\":\"#000000\",\"text\":\"#ffffff\",\"accent\":\"#e74c3c\"}")
  isActive  Boolean  @default(false)
  pages     String   @default("[\"product\"]")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([shop])
}

model AppSettings {
  id        String   @id @default(cuid())
  shop      String   @unique
  isEnabled Boolean  @default(true)
  settings  String   @default("{\"fontFamily\":\"inherit\",\"colorScheme\":\"light\"}")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model DeliverySettings {
  id          String   @id @default(cuid())
  shop        String   @unique
  isEnabled   Boolean  @default(false)
  apiToken    String   @default("")
  originPin   String   @default("")
  bufferDays   Int     @default(1)
  environment  String  @default("staging")
  placement    String  @default("below-atc")
  deliveryMode String  @default("standard") // "standard" | "express" | "both"
  headingText      String  @default("Estimate delivery date")
  deliverByText    String  @default("Delivery by")
  freeDeliveryOn   Boolean @default(false)
  freeDeliveryText String  @default("Free delivery")
  fasterNoteOn     Boolean @default(false)
  fasterNoteText   String  @default("Faster delivery methods available at checkout")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model OrderManageSettings {
  id               String   @id @default(cuid())
  shop             String   @unique
  isEnabled        Boolean  @default(false)
  allowCancel      Boolean  @default(true)
  cancelScope      String   @default("unpaid") // "unpaid" | "all"
  allowAddressEdit Boolean  @default(true)
  showOnPages      String   @default("[\"account\"]") // JSON array: "account" | "account-new" | "thank-you"
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model WishlistSettings {
  id               String   @id @default(cuid())
  shop             String   @unique
  isEnabled        Boolean  @default(false)
  showOnCards      Boolean  @default(true)
  cardPosition     String   @default("top-right") // top-right | top-left
  showOnProduct    Boolean  @default(true)
  productPlacement String   @default("below-atc") // below-atc | above-atc
  showHeader       Boolean  @default(true)
  iconColor        String   @default("#e74c3c")
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model Wishlist {
  id         String   @id @default(cuid())
  shop       String
  customerId String
  handles    String   @default("[]") // JSON array of product handles
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([shop, customerId])
}

model BackInStockSettings {
  id          String   @id @default(cuid())
  shop        String   @unique
  isEnabled   Boolean  @default(false)
  placement   String   @default("below-atc") // below-atc | above-atc | replace-button
  buttonText  String   @default("Notify me when available")
  headingText String   @default("Get notified when this is back")
  consentText String   @default("We'll message you on WhatsApp when it's back in stock.")
  successText String   @default("Done! We'll WhatsApp you when it's back in stock.")

  // WhatsApp delivery. The shopper's number is first-party data typed into the
  // storefront form, so notifying needs no customer records and no Protected
  // Customer Data access. The merchant brings their own provider account.
  waEnabled      Boolean @default(false)
  waProvider     String  @default("interakt") // "interakt" | "doubletick"
  waApiKey       String  @default("") // provider secret; Interakt's is base64 and sent verbatim
  waTemplateName String  @default("")
  waLanguageCode String  @default("en")
  waFromNumber   String  @default("") // DoubleTick only: the sender WhatsApp number
  // Template header image. Products without a featured image fall back to this
  // so one image template covers every send (Meta rejects an empty header).
  waFallbackImage String @default("")

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model BackInStockSubscription {
  id         String    @id @default(cuid())
  shop       String
  variantId  String
  productId  String
  phone      String // WhatsApp number — the shopper's identity here
  notifiedAt DateTime? // set ONLY once the provider accepted the message
  createdAt  DateTime  @default(now())

  @@unique([shop, variantId, phone])
  @@index([shop, variantId])
  @@index([shop])
}

model AiReplySettings {
  id           String   @id @default(cuid())
  shop         String   @unique
  isEnabled    Boolean  @default(false)
  apiKey       String   @default("") // merchant's Gemini key — server-side only
  knowledge    String   @default("") // policies/FAQ text the bot may answer from
  botName      String   @default("Support")
  greeting     String   @default("Hi! Ask me about shipping, returns or sizing.")
  supportEmail String   @default("")
  supportUrl   String   @default("")
  accentColor  String   @default("#111111")
  position     String   @default("bottom-right") // bottom-right | bottom-left

  // Inbound AI replies over WhatsApp. The same knowledge base and Gemini key
  // answer both channels; only the delivery path differs. Set independently of
  // the Back in Stock provider — a merchant may run alerts on one and chat on
  // the other.
  waReplyEnabled  Boolean @default(false)
  waProvider      String  @default("interakt") // "interakt" | "doubletick"
  waApiKey        String  @default("") // provider send key; Interakt's is base64, sent verbatim
  waWebhookSecret String  @default("") // Interakt secret_key, for HMAC verification
  // Opaque per-shop token in the webhook URL. Neither provider's payload names
  // which business number received the message, so the token is the only thing
  // identifying the shop. Uniqueness is enforced by a PARTIAL index (migration
  // 0021) because "" is the shared default.
  waWebhookToken  String  @default("")
  // DoubleTick only. Its send API requires a `from` sender number, and its
  // webhook carries NO signature — it echoes a bearer token we choose at
  // registration, so that token is what we verify instead of an HMAC.
  waFromNumber    String  @default("")
  waWebhookAuth   String  @default("")

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([waWebhookToken])
}

/// One rolling WhatsApp thread per shopper. Kept only long enough for the bot to
/// follow the conversation, then purged — see PURGE_AFTER_HOURS in the cron.
model WhatsAppConversation {
  id            String   @id @default(cuid())
  shop          String
  phone         String // normalised 10-digit — the conversation key
  turns         String   @default("[]") // JSON ChatTurn[]; capped via trimHistory()
  optedOut      Boolean  @default(false) // handoff keyword sent; bot stays silent
  windowCount   Int      @default(0) // replies sent in the current rate-limit window
  windowStart   DateTime @default(now())
  lastInboundAt DateTime @default(now())
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([shop, phone])
  @@index([updatedAt]) // for the purge sweep
}

/// Inbound message awaiting an AI reply. Exists because Interakt demands a 200
/// within 3s while Gemini can take 15s — the webhook records the job and a cron
/// drains it. A row is also the only durable record if a send fails.
model WhatsAppReplyJob {
  id                String   @id @default(cuid())
  shop              String
  phone             String
  message           String
  providerMessageId String // Interakt's data.message.id — the idempotency key
  status            String   @default("pending") // pending | claimed | done | failed
  attempts          Int      @default(0)
  error             String   @default("")
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@unique([shop, providerMessageId]) // a redelivered webhook must not double-reply
  @@index([status, createdAt])
}

model ShopPlan {
  id        String   @id @default(cuid())
  shop      String   @unique
  plan      String   @default("free")
  billingId String?
  status    String   @default("active")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
